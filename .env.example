# Local infrastructure defaults
ATLAS_POSTGRES_HOST=127.0.0.1
ATLAS_POSTGRES_PORT=5432
ATLAS_POSTGRES_DB=atlas_bastion
ATLAS_POSTGRES_USER=atlas
ATLAS_POSTGRES_PASSWORD=atlas

ATLAS_REDIS_HOST=127.0.0.1
ATLAS_REDIS_PORT=6379

ATLAS_MINIO_ENDPOINT=http://127.0.0.1:9000
ATLAS_MINIO_CONSOLE_URL=http://127.0.0.1:9001
ATLAS_MINIO_ACCESS_KEY=atlas
ATLAS_MINIO_SECRET_KEY=atlasminio
ATLAS_MINIO_BUCKET=atlas-artifacts

# Service defaults
ATLAS_API_HOST=127.0.0.1
ATLAS_API_PORT=8000
ATLAS_API_ENVIRONMENT=local
ATLAS_API_LOG_LEVEL=INFO

ATLAS_WORKER_HOST=127.0.0.1
ATLAS_WORKER_PORT=8100
ATLAS_WORKER_ENVIRONMENT=local
ATLAS_WORKER_LOG_LEVEL=INFO
